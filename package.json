{
  "name": "express-middleware-performance-logger",
  "version": "1.0.0",
  "type": "module",
  "description": "Developer tool to monitor RESTful API performance",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "epl-init": "./dist/bin/cli.js"
  },
  "peerDependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "supertest": "^7.2.2",
    "typescript": "^5.8.2"
  }
}
